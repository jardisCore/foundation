{
    "name": "jardiscore/foundation",
    "homepage": "https://jardis.io",
    "description": "ENV-driven integration platform for PHP — wires DB, cache, logger, events, HTTP, mail and filesystem into ready-to-use services; the runtime foundation that Jardis-generated DDD code runs on",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Jardis Development",
            "email": "jardisDev@headgent.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "jardis/dev-skills": "^1.0",
        "jardiscore/kernel": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0.4",
        "squizlabs/php_codesniffer": "^3.11.2",
        "jardisadapter/cache": "^1.0",
        "jardisadapter/dbconnection": "^1.0",
        "jardisadapter/eventdispatcher": "^1.0",
        "jardisadapter/filesystem": "^1.0",
        "jardisadapter/http": "^1.0",
        "jardisadapter/logger": "^1.0",
        "jardisadapter/mailer": "^1.0"
    },
    "suggest": {
        "jardisadapter/cache": "For multi-layer caching (Memory, Redis, Database)",
        "jardisadapter/dbconnection": "For ConnectionPool with read/write splitting",
        "jardisadapter/eventdispatcher": "For PSR-14 event dispatching",
        "jardisadapter/filesystem": "For local and S3 filesystem abstraction",
        "jardisadapter/http": "For PSR-18 HTTP client with handler pipeline",
        "jardisadapter/logger": "For log handlers (File, Console, Redis, Database, etc.)",
        "jardisadapter/mailer": "For SMTP mailer with STARTTLS, AUTH, HTML/text, attachments",
        "ext-redis": "For Redis-based caching and logging"
    },
    "autoload": {
        "psr-4": {
            "JardisCore\\Foundation\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JardisCore\\Foundation\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "jardis/dev-skills": true
        }
    },
    "support": {
        "issues": "https://github.com/jardisCore/foundation/issues",
        "docs": "https://docs.jardis.io/en/core/foundation",
        "email": "jardisDev@headgent.com"
    },
    "keywords": [
        "domain",
        "foundation",
        "integration-platform",
        "domain-driven-design",
        "hexagonal-architecture",
        "code-generation",
        "ddd",
        "php",
        "jardis",
        "headgent"
    ]
}
